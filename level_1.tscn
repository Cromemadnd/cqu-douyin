[sub_resource type="Shader" id="Shader_1pe0h"]
code = "shader_type spatial;
// 1. 【核心】cull_disabled 必须开启！这样显卡才会去画被切开后的内壁（背面）
// unshaded 保证填充纯色，不受光照干扰
render_mode unshaded, cull_disabled;

uniform vec4 fill_color : source_color = vec4(0.0, 1.0, 0.0, 1.0); // 填充纯色
uniform float slice_distance = 5.0; // 5米切面

void fragment() {
	// 获取当前像素在相机空间下的 Z 轴深度
	float depth = -VERTEX.z;
	
	// 2. 【枪毙逻辑】彻底解决“过近、过远像素没消失”的问题
	// 任何比 5 米近的像素（包含物体的正面外壳），统统人间蒸发！
	if (depth < slice_distance) {
		discard;
	}
	
	// 3. 【剩余像素处理】此时能活下来的，统统全都是距离大于 5 米的像素。
	// 也就是物体的内壁后表面。
	
	// 我们利用 FRONT_FACING 判断：如果我是背面（!FRONT_FACING）
	if (!FRONT_FACING) {
		// 它的存在就证明 5 米处的空间是实心的，我们把它逆向投影并涂成实心绿色！
		ALBEDO = fill_color.rgb;
	} else {
		// 【可选项】
		// 如果是大于 5 米的正面像素（比如切片后面的其他完整 3D 物体）
		// 如果你们不想看到它，就直接 discard 枪毙；如果想当成背景就保留
		discard; 
	}
}"

