[sub_resource type="Shader" id="Shader_jka67"]
code = "shader_type canvas_item;

uniform sampler2D screen_texture : hint_screen_texture, filter_nearest;

// 调整对绿色的敏感度
uniform vec3 target_green = vec3(0.0, 1.0, 0.0); 
uniform float tolerance = 0.2;

// 最大扫描像素半径（比如只往左/右各扫 200 个像素，超出就不管了，避免无限循环卡死显卡）
uniform int max_scan_pixels = 300; 

bool is_green(vec3 color) {
    return distance(color, target_green) < tolerance;
}

void fragment() {
    // SCREEN_PIXEL_SIZE.x 代表当前分辨率下，单个像素在 UV 坐标系中的宽度
    float one_pixel = SCREEN_PIXEL_SIZE.x;
    
    vec4 current_color = texture(screen_texture, SCREEN_UV);
    
    if (is_green(current_color.rgb)) {
        COLOR = vec4(0.5, 0.5, 0.5, 1.0);
    } else {
        bool has_green_left = false;
        bool has_green_right = false;
        
        // 1. 基于像素精准向左扫描
        for (int i = 1; i <= max_scan_pixels; i++) {
            float scan_x = SCREEN_UV.x - (float(i) * one_pixel);
            if (scan_x < 0.0) break; // 撞到屏幕左边缘，停
            
            vec3 c = texture(screen_texture, vec2(scan_x, SCREEN_UV.y)).rgb;
            if (is_green(c)) {
                has_green_left = true;
                break;
            }
        }
        
        // 2. 基于像素精准向右扫描
        for (int i = 1; i <= max_scan_pixels; i++) {
            float scan_x = SCREEN_UV.x + (float(i) * one_pixel);
            if (scan_x > 1.0) break; // 撞到屏幕右边缘，停
            
            vec3 c = texture(screen_texture, vec2(scan_x, SCREEN_UV.y)).rgb;
            if (is_green(c)) {
                has_green_right = true;
                break;
            }
        }
        
        if (has_green_left && has_green_right) {
            COLOR = vec4(0.5, 0.5, 0.5, 1.0);
        } else {
            COLOR = current_color;
        }
    }
}"

