[sub_resource type="Shader" id="Shader_r3fl7"]
code = "shader_type spatial;
// 必须关闭光照和剔除，只渲染这层薄皮
render_mode unshaded, cull_disabled; 

uniform vec4 slice_color : source_color = vec4(0.0, 1.0, 0.0, 1.0); // 切面颜色（绿）
uniform float slice_center = 5.0; // 切片中心点距离相机 5 米
uniform float slice_thickness = 0.05; // 切片厚度（10厘米）

void fragment() {
	float depth = -VERTEX.z;
	
	// 计算当前像素到 5 米切片中心的绝对距离
	float distance_to_slice = abs(depth - slice_center);
	
	// 【核心修正】
	// 如果距离超过了厚度的一半，说明它在切片“外面”（不管太近还是太远）
	// 直接干掉，让它彻底隐形消失！
	if (distance_to_slice > (slice_thickness * 0.5)) {
		discard;
	}
	
	// 只有活下来的（刚好在切片内的）像素，才会被涂成纯绿色
	ALBEDO = slice_color.rgb;
}"

